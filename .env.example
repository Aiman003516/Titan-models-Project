# RunPod Serverless (Titan fine-tuned models)
RUNPOD_API_KEY=rpa_your_key_here
TITAN_BACKEND_ENDPOINT=https://api.runpod.ai/v2/your_backend_id
TITAN_UI_ENDPOINT=https://api.runpod.ai/v2/your_ui_id

# Groq (Tier-2 debugging LLM - free)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Generation parameters
TITAN_TEMPERATURE=0.6
TITAN_MAX_TOKENS=16384
DEBUG_TEMPERATURE=0.3
DEBUG_MAX_TOKENS=8192
MAX_DEBUG_RETRIES=3

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
